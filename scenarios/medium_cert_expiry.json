      "app-service"
    ],
    "app-service": [
      "auth-proxy",
      "session-store"
    ],
    "auth-proxy": [
      "session-store"
    ],
    "session-store": []
  },
  "fault_service": "auth-proxy",
  "fault_type": "cert_expiry",
  "fault_severity": 0.12,
  "playbook_effects": {
    "renew_certificate": {
      "target": "auth-proxy",
      "heal_amount": 0.90
    },
    "restart_auth_proxy": {
      "target": "auth-proxy",
      "heal_amount": 0.25
    },
    "flush_session_store": {
      "target": "session-store",
      "heal_amount": 0.35
    },
    "rollback_config": {
      "target": "app-service",
      "heal_amount": 0.30
    },
    "restart_app": {
      "target": "app-service",
      "heal_amount": 0.20
    },
    "scale_postgres_pool": {
      "target": "session-store",
      "heal_amount": 0.20
    }
  },
  "available_playbooks": [
    "renew_certificate",
    "restart_auth_proxy",
    "flush_session_store",
    "rollback_config",
    "restart_app",
    "scale_postgres_pool"
  ],
