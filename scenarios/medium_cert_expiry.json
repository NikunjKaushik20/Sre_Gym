{
  "scenario_id": "medium_cert_expiry",
  "difficulty": "medium",
  "description": "mTLS certificate expiry on internal auth-proxy — symptoms appear as auth failures and connection resets, not obvious TLS errors",
  "services": [
    "auth-proxy",
    "session-store",
    "app-service",
    "api-gateway"
  ],
