{
  "scenario_id": "hard_deploy_regression",
  "difficulty": "hard",
  "description": "Auth service v2.3.1 deploy breaks token validation",
  "services": [
    "auth-service",
    "user-service",
    "redis",
    "app-service",
    "api-gateway"
  ],
  "dependency_graph": {
    "api-gateway": [
      "app-service"
    ],
    "app-service": [
      "auth-service",
      "user-service"
    ],
    "auth-service": [
      "redis"
    ],
    "user-service": [],
    "redis": []
  },
  "fault_service": "auth-service",
  "fault_type": "deploy_regression",
  "fault_severity": 0.1,
  "playbook_effects": {
    "rollback_config": {
      "target": "auth-service",
      "heal_amount": 0.9
    },
    "restart_redis": {
