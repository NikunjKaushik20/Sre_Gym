      "heal_amount": 0.4
    },
    "restart_app": {
      "target": "app-service",
      "heal_amount": 0.3
    },
    "restart_gateway": {
      "target": "api-gateway",
      "heal_amount": 0.3
    },
    "scale_postgres_pool": {
      "target": "postgres",
      "heal_amount": 0.3
    },
    "flush_redis_cache": {
      "target": "redis",
      "heal_amount": 0.3
    }
  },
  "available_playbooks": [
    "rollback_config",
    "restart_redis",
    "restart_app",
    "restart_gateway",
    "scale_postgres_pool",
    "flush_redis_cache"
  ],
  "service_logs": {
