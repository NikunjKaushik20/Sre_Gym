{
  "scenario_id": "hard_config_cascade",
  "difficulty": "hard",
  "description": "Bad config deploy in config-service cascading through auth and redis",
  "services": [
    "config-service",
    "auth-service",
    "redis",
    "app-service",
    "api-gateway"
  ],
  "dependency_graph": {
    "api-gateway": [
      "app-service"
    ],
    "app-service": [
      "auth-service"
    ],
    "auth-service": [
      "config-service",
      "redis"
    ],
    "config-service": [],
    "redis": []
  },
  "fault_service": "config-service",
  "fault_type": "bad_config_deploy",
  "fault_severity": 0.1,
  "playbook_effects": {
    "rollback_config": {
      "target": "config-service",
      "heal_amount": 0.9
    },
    "restart_redis": {
      "target": "redis",
      "heal_amount": 0.4
    },
    "restart_app": {
      "target": "app-service",
      "heal_amount": 0.3
    },
    "restart_gateway": {
      "target": "api-gateway",
      "heal_amount": 0.3
    },
    "scale_postgres_pool": {
      "target": "postgres",
      "heal_amount": 0.3
    },
    "flush_redis_cache": {
      "target": "redis",
      "heal_amount": 0.3
    }
  },
  "available_playbooks": [
    "rollback_config",
    "restart_redis",
    "restart_app",
    "restart_gateway",
    "scale_postgres_pool",
    "flush_redis_cache"
  ],
  "service_logs": {
    "config-service": [
      {
        "msg": "Config push failed: invalid JSON in auth.yaml",
        "level": "fatal"
      }
    ],
    "auth-service": [
      {
        "msg": "Config refresh failed \u2014 using stale config",
        "level": "error"
      }
    ],
    "redis": [
      {
        "msg": "Memory spike \u2014 cache invalidation storm (red herring)",
        "level": "warn"
      }
    ],
    "app-service": [
      {
        "msg": "Auth service returning 500",
        "level": "error"
      }
    ],
    "api-gateway": [
      {
        "msg": "Cascading 503 on all routes",
        "level": "error"
      }
    ]
  },
  "red_herrings": [
    {
      "service": "redis",
      "symptom": "Memory spike from cache invalidation",
      "explanation": "Cache storm triggered by config push \u2014 resolves when config fixed"
    },
    {
      "service": "app-service",
      "symptom": "High error rate",
      "explanation": "Downstream symptom, not root cause"
    }
  ],
  "max_steps": 20,
  "affected_services": [
    "config-service",
    "auth-service",
    "redis",
    "app-service",
    "api-gateway"
  ],
  "valid_prevention_steps": [
    "config_validation_ci",
    "canary_deploy",
    "staging_parity"
  ],
  "min_timeline_steps": 3,
  "correct_escalation_team": "infrastructure"
}